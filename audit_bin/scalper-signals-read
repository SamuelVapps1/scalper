#!/usr/bin/env bash
# scalper-signals-read
# READ-ONLY: Prints signals_enriched_log.csv (or tail if large).
# No writes, no mutation.
set -euo pipefail
SCALPER_ROOT="${SCALPER_ROOT:-/root/scalper}"
SIG="${SCALPER_ROOT}/signals_enriched_log.csv"
if [[ -f "${SIG}" ]]; then
  n=$(wc -l < "${SIG}" 2>/dev/null || echo 0)
  if [[ "${n:-0}" -gt 1000 ]]; then
    head -n 1 "${SIG}"
    tail -n 999 "${SIG}"
  else
    cat "${SIG}"
  fi
else
  echo "[scalper-signals-read] ${SIG} not found"
fi
