# Public market scan settings
WATCHLIST=BTCUSDT,ETHUSDT
WATCHLIST_MODE=static
WATCHLIST_TOP_N=10
WATCHLIST_REFRESH_MINUTES=60
# WATCHLIST_REFRESH_MIN=10  # alias for dynamic mode cache
WATCHLIST_MIN_PRICE=0.01
WATCHLIST_MIN_TURNOVER_24H=100000000
# MIN_TURNOVER_USDT=50000000  # alias for dynamic mode
WATCHLIST_EXCLUDE_PREFIXES=1000,10000
WATCHLIST_EXCLUDE_SYMBOLS=PEPEUSDT,FLOKIUSDT,BONKUSDT
WATCHLIST_EXCLUDE_REGEX=
WATCHLIST_MAX_SPREAD_BPS=
# Dynamic mode: volatility filter (24h range %)
MIN_VOL_PCT=0.8
MAX_VOL_PCT=8.0
INTERVAL=15
LOOKBACK=300
SCAN_SECONDS=60

# MTF (Multi-Timeframe) pipeline: 4H/1H/15m/5m
TF_BIAS=240
TF_SETUP=60
TF_TRIGGER=15
TF_TIMING=5
LOOKBACK_4H=300
LOOKBACK_1H=300
LOOKBACK_15M=500
LOOKBACK_5M=800
CANDLES_CACHE_TTL_SECONDS=20

# Optional: override Bybit API base URL
BYBIT_BASE_URL=https://api.bybit.com

# Optional Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
HEARTBEAT_MINUTES=10
NOTIFY_SCAN_SUMMARY=0
DISABLE_SCAN_SUMMARY=1
TELEGRAM_POLICY=events
SCAN_SUMMARY_MINUTES=30
MAX_OPEN_POSITIONS=3
MARGIN_MODE=isolated
EARLY_ENABLED=1
EARLY_TF=5
EARLY_LOOKBACK_5M=180
EARLY_MIN_CONF=0.35
EARLY_REQUIRE_15M_CONTEXT=1
EARLY_MAX_ALERTS_PER_SYMBOL_PER_15M=1

DB_PATH=./data/scalper.db
POSITION_MODE=per_symbol
MAX_CONCURRENT_POSITIONS=5
ONE_POSITION=0
# Strategy/Indicators
RANGE_LOOKBACK_BARS=80
RANGE_EXCLUDE_TAIL=2
MIN_RANGE_ATR=2.0

# Execution realism (paper)
SPREAD_BPS=2
SLIPPAGE_BPS=3

# Scoring threshold
MIN_SCORE=0.0