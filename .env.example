# =========================================================
# SCALPER - CANONICAL ENV (single source of truth)
# Works for: python -m scalper.scanner --once/--loop --paper
# Goal: market watchlist rotation 200/20 + operator-grade Telegram
# =========================================================

# ======================
# Core scan
# ======================
INTERVAL=5
LOOKBACK=300
SCAN_SECONDS=60
REQUEST_SLEEP_MS=250
BYBIT_BASE_URL=https://api.bybit.com
LOG_LEVEL=INFO

# Cooldown (per symbol+setup alert dedup)
COOLDOWN_MINUTES=20

# ======================
# Watchlist / Universe
# ======================
# Modes:
# - static: use WATCHLIST
# - market: fetch Bybit linear tickers, build universe, rotate batches
WATCHLIST_MODE=market

# Static fallback list (used when WATCHLIST_MODE=static OR market fetch fails)
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,AVAXUSDT,LINKUSDT

# MARKET mode: universe+rotation (target: 200 pool / 20 active)
WATCHLIST_UNIVERSE_N=200
WATCHLIST_BATCH_N=20
WATCHLIST_REFRESH_SECONDS=900
WATCHLIST_ROTATE_MODE=roundrobin
WATCHLIST_ROTATE_SEED=0
ROTATION_STATE_FILE=data/watchlist_rotation_state.json

# Market filters
WATCHLIST_MIN_TURNOVER_24H=20000000
WATCHLIST_MIN_PRICE=0
WATCHLIST_MAX_SPREAD_BPS=25

# Exclusions / hygiene
WATCHLIST_EXCLUDE_PREFIXES=
WATCHLIST_EXCLUDE_SYMBOLS=FARTCOINUSDT,PIPPINUSDT,HYPEUSDT
WATCHLIST_EXCLUDE_REGEX=

# ======================
# Legacy aliases (keep consistent)
# (keep these to avoid breaking old code paths; set them to match the canonical values)
# ======================
WATCHLIST_REFRESH_MINUTES=15
WATCHLIST_TOP_N=10

UNIVERSE_MODE=dynamic
UNIVERSE_SIZE=200
BATCH_SIZE=20
UNIVERSE_REFRESH_HOURS=6
MIN_24H_TURNOVER=20000000

# ======================
# Volatility / ATR filters (used by risk/intent logic)
# ======================
MIN_VOL_PCT=0.2
MAX_VOL_PCT=25.0

MIN_ATR_PCT=0.0015
MIN_ATR_PCT_15M=0.05
MAX_ATR_PCT_15M=1.8

# ======================
# Multi-timeframe setup
# ======================
TF_BIAS=240
TF_SETUP=60
TF_TRIGGER=15
TF_TIMING=5

LOOKBACK_4H=200
LOOKBACK_1H=200
LOOKBACK_15M=300
LOOKBACK_5M=300

CANDLES_CACHE_TTL_SECONDS=120

CACHE_ONLY_GAP_BARS_MAX=12
CACHE_ONLY_MAX_TRUNC_PCT=0.5
CACHE_ONLY_ALLOW_TRUNCATION=1

REQUIRE_1H_EMA200_ALIGN=0
REQUIRE_5M_EMA20_CONFIRM=0

MAX_ALERTS_PER_SYMBOL_PER_15M=2
DEDUP_BARS=1

# ======================
# Risk / Execution
# ======================
EXECUTION_MODE=disabled
EXPLICIT_CONFIRM_EXECUTION=0
KILL_SWITCH=0

MARGIN_MODE=isolated
POSITION_MODE=per_symbol

MAX_CONCURRENT_POSITIONS=10
MAX_OPEN_POSITIONS=10
MAX_OPEN_TRADES=10
ONE_POSITION=0

MAX_DAILY_LOSS_USDT=100
RISK_MAX_TRADES_PER_DAY=999999
MAX_TRADES_DAY=999999

COOLDOWN_AFTER_LOSS_MIN=0
RISK_COOLDOWN_MINUTES=0
SYMBOL_COOLDOWN_BARS=0
GLOBAL_COOLDOWN_BARS=0

# ======================
# Paper trading realism
# ======================
PAPER_POSITION_USDT=20
PAPER_START_EQUITY_USDT=1000
PAPER_FEES_BPS=6
PAPER_SLIPPAGE_PCT=0.01
PAPER_FEE_PCT=0.055

PAPER_SL_ATR=1.0
PAPER_TP_ATR=1.5
PAPER_TIMEOUT_BARS=24

# TP/SL defaults for previews / allow events
SL_ATR_MULT=1.0
TP_ATR_MULT=1.5

# Exit logic / extras
TP_R=2.0
SL_ATR=0.8
SL_BUFFER_ATR=0.2
TOL_ATR=0.05
PULLBACK_TOL_ATR=0.5

SPREAD_BPS=2
SLIPPAGE_BPS=3

BE_AT_R=1.0
PARTIAL_TP_AT_R=1.0
PARTIAL_TP_PCT=0.5
TRAIL_AFTER_R=0
TRAIL_ATR_MULT=1.0

TIME_STOP_BARS=6
TIME_STOP_MIN_R=0.3
REPLAY_EXIT_MODE=hard

# ======================
# Strategy selection
# ======================
STRATEGIES_ENABLED=RB_RTG,TP_EMA20,FB_FADE,REV_SWEPT_RSI
REV_ENABLED=1
STRATEGY_V1=0
V1_SETUP_TRAP=0
V1_SETUP_BREAKOUT=0
V2_TREND_PULLBACK=1
DIVERGENCE_ENABLED=1

# Strategy knobs
RANGE_LOOKBACK_BARS=80
RANGE_EXCLUDE_TAIL=2
MIN_RANGE_ATR=2.5
MIN_SCORE=0.0

TRAP_MIN_WICK_ATR=0.6
TRAP_CLOSE_BACK_ATR=0.15
BREAKOUT_BUFFER_ATR=0.12

MAX_ABS_DIST_PCT_4H=12
DIST_SKIP_PCT_4H=40
DIST_SCORE_PENALTY=-1.0

EMA_PULLBACK_ENABLED=0
RETEST_CONFIRM_MODE=bos
BOS_LOOKBACK_5M=20
BREAKOUT_STRONG_MARKET=1
BREAKOUT_STRONG_BODY_PCT=0.6

TREND_MIN_SEP_ATR=1.0
MOMO_CONFIRM_5M=1
MOMO_MIN_BODY_ATR_5M=0.3

# REV tuning
REV_SWEEP_LOOKBACK_BARS=20
REV_SWEEP_TOL_ATR=0.10
REV_MIN_RSI_DELTA=2.0
REV_EMA200_DIST_PCT=0.03
REV_ENTRY_MODE=close
REV_REQUIRE_1H_ALIGN=0
REV_MAX_TREND_SEP_ATR_1H=3.0

# LSR tuning
LSR_MIN_WICK_RATIO=0.35
LSR_LOOKBACK_BARS=30
LSR_SWEEP_TOL_ATR=0.25
LSR_EMA_TOL_PCT=0.003
LSR_SL_ATR_MULT=0.35
LSR_MAX_TP_ATR_MULT=6.0
LSR_ENTRY_MODE=close

# RSI divergence
DIVERGENCE_RSI_PERIOD=14
DIVERGENCE_PIVOT_LEFT=3
DIVERGENCE_PIVOT_RIGHT=3
DIVERGENCE_LOOKBACK_PIVOTS=4
DIVERGENCE_CONFIRM_MODE=ema20
DIVERGENCE_MIN_RSI_DELTA=3.0
DIVERGENCE_MIN_PRICE_DELTA_ATR=0.3

# Extra MTF knobs
DONCHIAN_N_15M=25
BODY_ATR_15M=0.30
TREND_SEP_ATR_1H=0.50
USE_5M_CONFIRM=0

# ======================
# Early alerts
# ======================
EARLY_ENABLED=1
EARLY_TF=5
EARLY_LOOKBACK_5M=180
EARLY_MIN_CONF=0.35
EARLY_REQUIRE_15M_CONTEXT=1
EARLY_MAX_ALERTS_PER_SYMBOL_PER_15M=1

# ======================
# Telegram
# ======================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Policy: off|signals|events|both
TELEGRAM_POLICY=events

TELEGRAM_DAILY_BUDGET=100
TELEGRAM_EARLY_ENABLED=0
TELEGRAM_EARLY_MAX_PER_SYMBOL_PER_15M=1
TELEGRAM_COMPACT=1

HEARTBEAT_MINUTES=5
NOTIFY_SCAN_SUMMARY=0
DISABLE_SCAN_SUMMARY=1
SCAN_SUMMARY_MINUTES=15

NOTIFY_BLOCKED=0
ALWAYS_NOTIFY_INTENTS=1
INCLUDE_WATCHLIST_IN_SUMMARY=0
DEBUG_BYPASS_RISK_IN_PAPER=0

# ======================
# Dashboard
# ======================
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_INCLUDE_MARKET_SNAPSHOT=1
DASHBOARD_TOP_N=3
DASHBOARD_INCLUDE_BLOCKED=1
SIGNAL_DEBUG=0

# ======================
# DB
# ======================
DB_PATH=./data/scalper.db