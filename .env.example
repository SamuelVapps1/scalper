# Scanner runtime
# Watchlist: static = use WATCHLIST; market = fetch Bybit linear tickers, filter, rotate 200/20
WATCHLIST_MODE=static
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT
WATCHLIST_UNIVERSE_N=200
WATCHLIST_BATCH_N=20
WATCHLIST_REFRESH_SECONDS=900
WATCHLIST_ROTATE_MODE=roundrobin
WATCHLIST_ROTATE_SEED=0
ROTATION_STATE_FILE=state.json
WATCHLIST_MIN_TURNOVER_24H=0
WATCHLIST_MIN_PRICE=0
WATCHLIST_EXCLUDE_PREFIXES=1000,10000
WATCHLIST_EXCLUDE_SYMBOLS=
WATCHLIST_EXCLUDE_REGEX=
WATCHLIST_MAX_SPREAD_BPS=0

# Aliases (optional): WATCHLIST_REFRESH_MINUTES, MIN_24H_TURNOVER, UNIVERSE_SIZE, BATCH_SIZE

INTERVAL=15
LOOKBACK=300
SCAN_SECONDS=60
REQUEST_SLEEP_MS=250
BYBIT_BASE_URL=https://api.bybit.com

# Telegram (placeholders only)
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_TELEGRAM_CHAT_ID>
TELEGRAM_POLICY=both
